# Copy this file to .env and fill in your values.
# Never commit .env to git.

# --- Your MongoDB connection ---
# Local MongoDB:
# MONGO_URL=mongodb://localhost:27017
#
# MongoDB Atlas (replace user, password, cluster):
# MONGO_URL=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority

MONGO_URL=mongodb://localhost:27017

# Database name on that server (create your own name if you want)
DB_NAME=portfolio_db

# Set to true once when switching to a new DB to load data from seed_data.py
RESEED_DB=false

# GitHub username for /api/github/stats
GITHUB_USERNAME=vijayanuganti

# Optional: GitHub personal access token (raises API rate limit on Render)
# Create at: GitHub → Settings → Developer settings → Personal access tokens (public read)
# GITHUB_TOKEN=

# Frontend URLs allowed for CORS (comma-separated)
# Local: http://localhost:3000
# Production: add your Vercel URL, e.g. https://your-portfolio.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Brevo (contact form email notifications)
# Get API key: Brevo Dashboard → SMTP & API → API Keys
# Verify sender: SMTP & API → Senders & IP
# If API is blocked by IP, disable Authorized IPs here:
# https://app.brevo.com/security/authorised_ips
BREVO_API_KEY=
BREVO_SENDER_EMAIL=your-verified-email@example.com
BREVO_SENDER_NAME=Your Name
CONTACT_RECIPIENT_EMAIL=your-verified-email@example.com

# Optional SMTP fallback (SMTP & API → SMTP in Brevo dashboard)
# BREVO_SMTP_LOGIN=your-brevo-account-login-email
# BREVO_SMTP_KEY=your-smtp-key
